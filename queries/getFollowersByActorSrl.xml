<?xml version="1.0" encoding="utf-8"?>
<query id="getFollowersByActorSrl" action="select">
	<tables>
		<table name="activitypub_followers" />
	</tables>
	<columns>
		<column name="*" />
	</columns>
	<conditions>
		<condition operation="equal" column="actor_srl" var="actor_srl" filter="number" notnull="notnull" />
	</conditions>
	<navigation>
		<index var="sort_index" default="follower_srl" order="desc" />
		<list_count var="list_count" default="100" />
		<page_count var="page_count" default="10" />
		<page var="page" default="1" />
	</navigation>
</query>
