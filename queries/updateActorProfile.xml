<?xml version="1.0" encoding="utf-8"?>
<query id="updateActorProfile" action="update">
	<tables>
		<table name="activitypub_actors" />
	</tables>
	<columns>
		<column name="display_name" var="display_name" />
		<column name="summary" var="summary" />
		<column name="icon_url" var="icon_url" />
	</columns>
	<conditions>
		<condition operation="equal" column="actor_srl" var="actor_srl" filter="number" notnull="notnull" />
	</conditions>
</query>
