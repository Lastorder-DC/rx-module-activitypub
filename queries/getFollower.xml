<?xml version="1.0" encoding="utf-8"?>
<query id="getFollower" action="select">
	<tables>
		<table name="activitypub_followers" />
	</tables>
	<columns>
		<column name="*" />
	</columns>
	<conditions>
		<condition operation="equal" column="actor_srl" var="actor_srl" filter="number" notnull="notnull" />
		<condition operation="equal" column="follower_actor_url" var="follower_actor_url" notnull="notnull" pipe="and" />
	</conditions>
</query>
