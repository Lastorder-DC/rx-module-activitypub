<?xml version="1.0" encoding="utf-8"?>
<query id="getActorByMemberSrl" action="select">
	<tables>
		<table name="activitypub_actors" />
	</tables>
	<columns>
		<column name="*" />
	</columns>
	<conditions>
		<condition operation="equal" column="actor_type" var="actor_type" notnull="notnull" />
		<condition operation="equal" column="member_srl" var="member_srl" filter="number" notnull="notnull" pipe="and" />
	</conditions>
</query>
